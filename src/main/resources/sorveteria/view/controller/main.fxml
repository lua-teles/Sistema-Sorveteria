<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sorveteria.view.controller.MainController">

    <children>
        <VBox AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <HBox alignment="CENTER_LEFT" styleClass="topbar">
                <Label styleClass="topbar-title" text="🍦 Sorveteria" />
                <Button onAction="#irPedidos" styleClass="navButton" text="Pedidos" />
                <Button onAction="#irMontagem" styleClass="navButton" text="Montagem" />
                <Button onAction="#irPreparo" styleClass="navButton" text="Preparo" />
                <Button onAction="#irEstoque" styleClass="navButton" text="Estoque" />
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#novoPedido" styleClass="botaoNovoPedido" text="+ Novo Pedido">
                    <HBox.margin><Insets right="8" /></HBox.margin>
                </Button>
            </HBox>
            <StackPane fx:id="container" VBox.vgrow="ALWAYS" />
        </VBox>
    </children>
</AnchorPane>
