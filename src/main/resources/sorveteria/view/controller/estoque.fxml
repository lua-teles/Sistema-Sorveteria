<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sorveteria.view.controller.EstoqueController">
    <children>
        <VBox AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <VBox spacing="16" styleClass="estoqueContainer" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label styleClass="titulo" text="Controle de Estoque" />
                    <Region HBox.hgrow="ALWAYS" />
                    <TextField fx:id="campoBusca" onKeyReleased="#filtrarIngredientes" prefWidth="220" promptText="Buscar ingrediente..." styleClass="textField" />
                    <TextField fx:id="campoNovoNome" prefWidth="180" promptText="Nome do ingrediente" />
                    <TextField fx:id="campoNovaQtd" prefWidth="70" promptText="Qtd." />
                    <Button onAction="#adicionarIngrediente" styleClass="botaoNovoPedido" text="+ Adicionar" />
                    <Button onAction="#adicionarIngrediente" styleClass="botaoSecundario" text="+ Adicionar Ingrediente" />
                </HBox>
                <TableView fx:id="tabelaEstoque" styleClass="tabelaEstoque" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNome" prefWidth="250" text="Ingrediente" />
                        <TableColumn fx:id="colQuantidade" prefWidth="150" text="Qtd. em Estoque" />
                        <TableColumn fx:id="colUnidade" prefWidth="100" text="Unidade" />
                        <TableColumn fx:id="colStatus" prefWidth="130" text="Status" />
                        <TableColumn fx:id="colAcoes" prefWidth="200" text="Ações" />
                    </columns>
                    <placeholder>
                        <Label styleClass="emptyStateText" text="Nenhum ingrediente cadastrado." />
                    </placeholder>
                </TableView>
                <HBox fx:id="painelAlertas" alignment="CENTER_LEFT" managed="false" spacing="8" visible="false">
                    <Label styleClass="resumoItemLabel" text="⚠ ATENÇÃO:" />
                    <Label fx:id="labelAlertas" styleClass="estoqueAlerta" text="Alguns ingredientes estão com estoque baixo." />
                </HBox>
            </VBox>
        </VBox>
    </children>
</AnchorPane>
