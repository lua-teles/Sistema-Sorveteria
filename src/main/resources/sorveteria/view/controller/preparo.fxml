<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane stylesheets="@styles.css" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sorveteria.view.controller.PreparoController">
    <children>
        <VBox AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <VBox styleClass="preparoContainer" VBox.vgrow="ALWAYS">
                <Label styleClass="titulo" text="Fila de Preparo" />
                <HBox fillHeight="true" spacing="16" VBox.vgrow="ALWAYS">
                    <VBox styleClass="colunaKanban" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label styleClass="kanbanHeader" text="AGUARDANDO" />
                            <Label fx:id="countAguardando" styleClass="badgeAberto" text="0" />
                        </HBox>
                        <Separator />
                        <ScrollPane fitToWidth="true" styleClass="scrollArea" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox fx:id="listaAguardando" spacing="8" />
                            </content>
                        </ScrollPane>
                    </VBox>
                    <VBox styleClass="colunaKanban" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label styleClass="kanbanHeader" text="EM PREPARO" />
                            <Label fx:id="countEmPreparo" styleClass="badgePreparo" text="0" />
                        </HBox>
                        <Separator />
                        <ScrollPane fitToWidth="true" styleClass="scrollArea" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox fx:id="listaEmPreparo" spacing="8" />
                            </content>
                        </ScrollPane>
                    </VBox>
                    <VBox styleClass="colunaKanban" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label styleClass="kanbanHeader" text="PRONTO" />
                            <Label fx:id="countPronto" styleClass="badgePronto" text="0" />
                        </HBox>
                        <Separator />
                        <ScrollPane fitToWidth="true" styleClass="scrollArea" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox fx:id="listaPronto" spacing="8" />
                            </content>
                        </ScrollPane>
                    </VBox>
                </HBox>
            </VBox>
        </VBox>
    </children>
</AnchorPane>
